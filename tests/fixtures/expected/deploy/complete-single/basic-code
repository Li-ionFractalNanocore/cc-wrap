#!/bin/bash
# This script encloses its environment the way a cell encloses the sea.

# basic-code - Use Claude Code with Basic API
# Generated by cc-wrap

# Check if BASIC_API_KEY is set
if [[ -z "${BASIC_API_KEY:-}" ]]; then
  echo "Error: BASIC_API_KEY environment variable is not set" >&2
  echo "Please set BASIC_API_KEY, e.g.: export BASIC_API_KEY='your-api-key'" >&2
  exit 1
fi

# Set provider configuration
export ANTHROPIC_BASE_URL='https://api.example.test/v1'
export ANTHROPIC_AUTH_TOKEN="$BASIC_API_KEY"
export ANTHROPIC_MODEL='basic-model'
export ANTHROPIC_REASONING_MODEL='basic-model'
export ANTHROPIC_DEFAULT_OPUS_MODEL='basic-model'
export ANTHROPIC_DEFAULT_SONNET_MODEL='basic-model'
export ANTHROPIC_DEFAULT_HAIKU_MODEL='basic-model'
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
export CLAUDE_CONFIG_DIR="$HOME/.config/claude-basic"

exec claude "$@"
