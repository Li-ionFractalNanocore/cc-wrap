#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/cc-wrap-common.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/cc-wrap-render.sh"

usage() {
  cat <<'EOF'
Usage:
  cc-wrap deploy [--config <path>]
  cc-wrap uninstall [--config <path>]
  cc-wrap list [--config <path>]
  cc-wrap --help

Commands:
  deploy    Generate wrapper scripts for all configured providers
  uninstall Remove managed wrapper scripts for all configured providers
  list      List configured providers

Options:
  --config <path>  Path to config file (default: ./cc-wrap.json)
  -h, --help       Show this help message
EOF
}

parse_args() {
  CONFIG_PATH="./cc-wrap.json"
  COMMAND=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      deploy|uninstall|list)
        [[ -z "$COMMAND" ]] || die "Only one command may be specified"
        COMMAND="$1"
        shift
        ;;
      --config)
        [[ $# -ge 2 ]] || die "--config requires a path"
        CONFIG_PATH="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  [[ -n "$COMMAND" ]] || {
    usage
    exit 1
  }
}

list_providers() {
  local config_path="$1"
  local provider_json script_name description

  while IFS= read -r provider_json; do
    script_name="$(jq -r '.script_name' <<<"$provider_json")"
    description="$(jq -r '.description // empty' <<<"$provider_json")"

    if [[ -n "$description" ]]; then
      printf '%s - %s\n' "$script_name" "$description"
    else
      printf '%s\n' "$script_name"
    fi
  done < <(stream_providers "$config_path")
}

write_provider_script() {
  local output_dir="$1"
  local provider_json="$2"
  local disable_nonessential_traffic="$3"
  local experimental_agent_teams="$4"
  local script_name target_path temp_path

  script_name="$(jq -r '.script_name' <<<"$provider_json")"
  target_path="$output_dir/$script_name"

  if [[ -e "$target_path" ]] && ! file_is_cc_wrap_managed "$target_path"; then
    printf 'Skipped existing unmanaged file: %s\n' "$target_path"
    return 1
  fi

  temp_path="$(mktemp "${target_path}.XXXXXX")"

  render_wrapper_script "$provider_json" "$disable_nonessential_traffic" "$experimental_agent_teams" >"$temp_path"
  chmod 755 "$temp_path"
  mv "$temp_path" "$target_path"
}

deploy_providers() {
  local config_path="$1"
  local output_dir disable_nonessential_traffic experimental_agent_teams provider_json provider_index generated_count skipped_count

  output_dir="$(jq -r '.output_dir // "./target"' "$config_path")"
  output_dir="$(expand_home_path "$output_dir")"
  mkdir -p "$output_dir"

  disable_nonessential_traffic="false"
  if config_has_value '.defaults.disable_nonessential_traffic' "$config_path"; then
    disable_nonessential_traffic="$(jq -r '.defaults.disable_nonessential_traffic' "$config_path")"
    [[ "$disable_nonessential_traffic" == "true" || "$disable_nonessential_traffic" == "false" ]] || die "defaults.disable_nonessential_traffic must be a boolean"
  fi

  experimental_agent_teams="false"
  if config_has_value '.defaults.experimental_agent_teams' "$config_path"; then
    experimental_agent_teams="$(jq -r '.defaults.experimental_agent_teams' "$config_path")"
    [[ "$experimental_agent_teams" == "true" || "$experimental_agent_teams" == "false" ]] || die "defaults.experimental_agent_teams must be a boolean"
  fi

  provider_index=0
  generated_count=0
  skipped_count=0
  while IFS= read -r provider_json; do
    provider_index=$((provider_index + 1))
    validate_provider_json "$provider_json" "$provider_index"
    if write_provider_script "$output_dir" "$provider_json" "$disable_nonessential_traffic" "$experimental_agent_teams"; then
      generated_count=$((generated_count + 1))
    else
      skipped_count=$((skipped_count + 1))
    fi
  done < <(stream_providers "$config_path")

  printf 'Generated %d wrapper script(s) in %s\n' "$generated_count" "$output_dir"
  if [[ "$skipped_count" -gt 0 ]]; then
    printf 'Skipped %d existing unmanaged file(s)\n' "$skipped_count"
  fi
}

remove_provider_script() {
  local output_dir="$1"
  local provider_json="$2"
  local script_name target_path

  script_name="$(jq -r '.script_name' <<<"$provider_json")"
  target_path="$output_dir/$script_name"

  if [[ ! -e "$target_path" ]]; then
    printf 'Missing file: %s\n' "$target_path"
    return 2
  fi

  if ! file_is_cc_wrap_managed "$target_path"; then
    printf 'Skipped existing unmanaged file: %s\n' "$target_path"
    return 1
  fi

  rm -f -- "$target_path"
}

uninstall_providers() {
  local config_path="$1"
  local output_dir provider_json provider_index removed_count skipped_count missing_count remove_status

  output_dir="$(jq -r '.output_dir // "./target"' "$config_path")"
  output_dir="$(expand_home_path "$output_dir")"

  provider_index=0
  removed_count=0
  skipped_count=0
  missing_count=0
  while IFS= read -r provider_json; do
    provider_index=$((provider_index + 1))
    validate_provider_json "$provider_json" "$provider_index"
    if remove_provider_script "$output_dir" "$provider_json"; then
      removed_count=$((removed_count + 1))
    else
      remove_status=$?
      case "$remove_status" in
        1)
          skipped_count=$((skipped_count + 1))
          ;;
        2)
          missing_count=$((missing_count + 1))
          ;;
        *)
          return "$remove_status"
          ;;
      esac
    fi
  done < <(stream_providers "$config_path")

  printf 'Removed %d wrapper script(s) from %s\n' "$removed_count" "$output_dir"
  if [[ "$skipped_count" -gt 0 ]]; then
    printf 'Skipped %d existing unmanaged file(s)\n' "$skipped_count"
  fi
  if [[ "$missing_count" -gt 0 ]]; then
    printf 'Missing %d file(s)\n' "$missing_count"
  fi
}

main() {
  ensure_command jq
  parse_args "$@"

  CONFIG_PATH="$(expand_home_path "$CONFIG_PATH")"
  validate_config_file "$CONFIG_PATH"

  case "$COMMAND" in
    deploy)
      deploy_providers "$CONFIG_PATH"
      ;;
    uninstall)
      uninstall_providers "$CONFIG_PATH"
      ;;
    list)
      local provider_json provider_index
      provider_index=0
      while IFS= read -r provider_json; do
        provider_index=$((provider_index + 1))
        validate_provider_json "$provider_json" "$provider_index"
      done < <(stream_providers "$CONFIG_PATH")
      list_providers "$CONFIG_PATH"
      ;;
  esac
}

main "$@"
